#pragma once

// ── Wi-Fi ───────────────────────────────────────────────────────────────────
// For WPA2-PSK, set WIFI_EAP_USERNAME to "" and use WIFI_PASSWORD.
// For WPA2-Enterprise (802.1X/EAP), set WIFI_EAP_USERNAME and WIFI_EAP_PASSWORD.

#define WIFI_SSID           "YOUR_WIFI_SSID"
#define WIFI_PASSWORD       "YOUR_WIFI_PASSWORD"
#define WIFI_EAP_IDENTITY   "anonymous@domain"
#define WIFI_EAP_USERNAME   ""
#define WIFI_EAP_PASSWORD   ""
#define WIFI_EAP_METHOD     WPA2_AUTH_PEAP


// ── MQTT Broker ─────────────────────────────────────────────────────────────

#define MQTT_SERVER         "192.168.1.100"
#define MQTT_PORT           1883
#define MQTT_USERNAME       ""
#define MQTT_PASSWORD       ""

// OTA Security Token (shared secret with dashboard)
#define OTA_TOKEN           "default_secret_token"